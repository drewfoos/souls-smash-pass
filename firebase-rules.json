{
  "rules": {
    // ── Global vote counts ────────────────────────────────────────────────────
    // Anyone can READ the leaderboard (public data).
    // Writes are BLOCKED — only the Firebase Admin SDK (used by API routes)
    // can write to /votes, bypassing these rules entirely.
    "votes": {
      ".read": true,
      ".write": false
    },

    // ── Per-user history ──────────────────────────────────────────────────────
    // Owner-only: each user can only read/write their own node.
    // Public profile pages are server-rendered using the Admin SDK (which
    // bypasses these rules), so there's no need for a public .read rule.
    // This prevents internal fields (currentId, lastPlayed, lastReset) from
    // leaking when isPublic is true.
    //
    // Admin SDK writes (vote recording, position sync) bypass ALL rules below.
    // The .validate rules only constrain direct client-side writes.
    "users": {
      "$uid": {
        ".read":  "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid",

        // ── Field-level validation ──────────────────────────────────────────
        // Prevents abuse even if client code is bypassed. Admin SDK is
        // unaffected — it bypasses rules entirely.

        "displayName": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 50)"
        },
        "tagline": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 160)"
        },
        "photoURL": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)"
        },
        "isPublic": {
          ".validate": "!newData.exists() || newData.isBoolean()"
        },
        "currentId": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000)"
        },
        "lastPlayed": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "lastReset": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "runConfig": {
          // Client only writes null (on reset). Admin writes the full object.
          // Allow both: null passes via !newData.exists(), object passes via
          // child validation. Seed is required for a valid run config.
          "seed": {
            ".validate": "newData.isNumber()"
          },
          "selectedGames": {
            ".validate": true
          },
          "selectedTypes": {
            ".validate": true
          },
          "$other": {
            ".validate": false
          }
        },
        "votes": {
          "$charId": {
            // Only "smash" or "pass" — prevents arbitrary data in vote entries.
            // remove() on the parent still works (deleting doesn't trigger child validate).
            ".validate": "newData.isString() && (newData.val() === 'smash' || newData.val() === 'pass')"
          }
        },

        // Reject unknown fields — prevents clients from writing arbitrary data
        // to the user node. Admin SDK bypasses this entirely.
        "$other": {
          ".validate": false
        }
      }
    },

    // ── Deleted / archived votes ──────────────────────────────────────────────
    // Users can read+write their own archive snapshots on reset.
    // Owner-only: needed so the client can prune old archives (keep latest 3).
    "deleted": {
      "$uid": {
        ".read":  "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid"
      }
    },

    // ── Anonymous session vote records ────────────────────────────────────
    // Written only by Admin SDK from API routes — no client access.
    // Keyed by SHA-256(sessionId) so raw session identifiers are never stored.
    // Structure: /anonVotes/{hashedSessionId}/{sanitizedCharId}: "smash"|"pass"
    //            /anonVotes/{hashedSessionId}/_lastSeen: timestamp
    "anonVotes": {
      ".read": false,
      ".write": false
    },

    // ── Rate limit counters ────────────────────────────────────────────────
    // Written only by Admin SDK from API routes — no client access.
    "rateLimit": {
      ".read": false,
      ".write": false
    },

    // Block all other paths by default
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
